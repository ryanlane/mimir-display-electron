# =============================================
# Mimir Display Electron – .env.local example
# =============================================
# Copy to .env.local and fill in your values.

# --- Display Identity ---
# Unique ID for this display (used as the MQTT topic prefix)
MIMIR_DISPLAY_ID=electron-display-01

# Human-readable name sent during pairing (optional)
# MIMIR_DISPLAY_NAME=Living Room Display

# --- Connection ---
# MQTT broker URL — must be reachable from this machine
MIMIR_MQTT_URL=mqtt://mimir.local:1883
# MIMIR_MQTT_URL=mqtt://192.168.1.100:1883

# Mimir server API URL — used to build the pairing QR code URL.
# Without this, a QR code won't be shown (manual code entry still works).
# MIMIR_API_URL=http://mimir.local:5000

# --- Security ---
# Allow HTTP (non-HTTPS) image URLs. Enable for local/LAN servers.
MIMIR_ALLOW_UNSAFE_HTTP=true

# Comma-separated hostname allowlist for image URLs. Blank = allow all.
# MIMIR_IMAGE_URL_ALLOWLIST=mimir.local,192.168.1.100

# --- Behavior ---
MIMIR_LOG_LEVEL=info
# MIMIR_LOG_LEVEL=debug

# Presence heartbeat interval in seconds (10–3600)
# MIMIR_PRESENCE_INTERVAL_S=60

# Enable mDNS advertisement of this display on the LAN
# MIMIR_MDNS_ENABLE=false

# --- Cache ---
# Total on-disk image cache budget in bytes (default 50 MB)
# MIMIR_CACHE_MAX_BYTES=50000000

# Per-image download size limit in bytes (default 5 MB)
# MIMIR_CACHE_MAX_IMAGE_BYTES=5000000

# --- Debug ---
# If set, a PNG screenshot is saved here after each successful content load
# MIMIR_DEBUG_SCREENSHOT_DIR=C:\temp\mimir-screenshots
